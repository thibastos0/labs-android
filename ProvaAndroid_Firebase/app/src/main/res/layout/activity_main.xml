<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml — Tela Inicial
    Contém: título de boas-vindas, card de descrição da prova e 2 botões de navegação.
    Guidelines:
      - ScrollView raiz para suportar fontes grandes / telas pequenas.
      - Todos os textos vêm de @string/ para facilitar manutenção e i18n.
      - Sem hardcode de cor; tudo referencia @color/.
      - Contraste mínimo 4.5:1 entre texto e fundo (WCAG AA).
      - Elementos touch têm minHeight >= 48dp.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="32dp"
        android:gravity="center_horizontal">

        <!-- Título de boas-vindas -->
        <TextView
            android:id="@+id/tv_home_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_title"
            android:textAppearance="@style/TextAppearance.ProvaAndroid.ScreenTitle"
            android:layout_marginBottom="24dp" />

        <!-- Card de descrição da prova -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            style="@style/Widget.ProvaAndroid.Card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Título do card -->
                <TextView
                    android:id="@+id/tv_card_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_card_title"
                    android:textAppearance="@style/TextAppearance.ProvaAndroid.CardTitle"
                    android:layout_marginBottom="8dp" />

                <!-- Descrição -->
                <TextView
                    android:id="@+id/tv_card_body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_card_body"
                    android:textAppearance="@style/TextAppearance.ProvaAndroid.Body"
                    android:layout_marginBottom="8dp" />

                <!-- Item 1 -->
                <TextView
                    android:id="@+id/tv_feature_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_feature_1"
                    android:textAppearance="@style/TextAppearance.ProvaAndroid.Body"
                    android:layout_marginBottom="4dp" />

                <!-- Item 2 -->
                <TextView
                    android:id="@+id/tv_feature_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_feature_2"
                    android:textAppearance="@style/TextAppearance.ProvaAndroid.Body" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botão 1: Calcular Média (roxo — estilo primário padrão) -->
        <Button
            android:id="@+id/btn_grades"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="@string/home_btn_grades"
            android:contentDescription="@string/home_btn_grades"
            android:drawableStart="@android:drawable/ic_menu_edit"
            android:drawablePadding="8dp"
            style="@style/Widget.ProvaAndroid.Button.Primary" />

        <!-- Botão 2: Cadastrar Aluno (verde) -->
        <Button
            android:id="@+id/btn_register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/home_btn_register"
            android:contentDescription="@string/home_btn_register"
            android:drawableStart="@android:drawable/ic_menu_add"
            android:drawablePadding="8dp"
            style="@style/Widget.ProvaAndroid.Button.Secondary" />

        <!-- Botão 3: Sair -->
        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="@string/home_btn_logout"
            android:contentDescription="@string/home_btn_logout"
            style="@style/Widget.ProvaAndroid.Button.Primary" />


    </LinearLayout>
</ScrollView>