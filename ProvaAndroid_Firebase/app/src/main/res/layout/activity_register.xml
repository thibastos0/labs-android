<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_register.xml — Tela de Cadastro (RegisterActivity)
    Contém: Toolbar com seta, campos RA / Nome / E-mail, botão salvar no SQLite
    e banner de sucesso que aparece após salvar.
    Guidelines:
      - inputType diferenciado por campo: number para RA, textPersonName para Nome,
        textEmailAddress para E-mail (ativa teclado email no dispositivo).
      - Banner de sucesso (card_success) inicia GONE; ativa-se após inserção OK.
      - android:autofillHints melhora experiência com autofill do Android.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".RegisterActivity">

    <!-- AppBar com Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar_register"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.ProvaAndroid.AppBarLayout">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar_register"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:contentDescription="@string/register_toolbar_title"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationContentDescription="@string/cd_btn_back"
            app:title="@string/register_toolbar_title"
            style="@style/Widget.ProvaAndroid.Toolbar" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Conteúdo principal -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <!-- Ícone centralizado -->
            <ImageView
                android:id="@+id/iv_register_icon"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="8dp"
                android:src="@android:drawable/ic_menu_add"
                android:contentDescription="@string/cd_icon_register" />

            <!-- Título da seção -->
            <TextView
                android:id="@+id/tv_register_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:text="@string/register_section_title"
                android:textAppearance="@style/TextAppearance.ProvaAndroid.ScreenTitle" />

            <!-- ── Campo RA ── -->
            <TextView
                android:id="@+id/lbl_ra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/register_label_ra"
                android:textAppearance="@style/TextAppearance.ProvaAndroid.Label"
                android:labelFor="@id/et_ra" />

            <EditText
                android:id="@+id/et_ra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/register_hint_ra"
                android:inputType="number"
                android:imeOptions="actionNext"
                android:maxLines="1"
                android:autofillHints="username"
                style="@style/Widget.ProvaAndroid.EditText" />

            <!-- ── Campo Nome ── -->
            <TextView
                android:id="@+id/lbl_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/register_label_name"
                android:textAppearance="@style/TextAppearance.ProvaAndroid.Label"
                android:labelFor="@id/et_name" />

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/register_hint_name"
                android:inputType="textPersonName|textCapWords"
                android:imeOptions="actionNext"
                android:maxLines="1"
                android:autofillHints="name"
                style="@style/Widget.ProvaAndroid.EditText" />

            <!-- ── Campo E-mail ── -->
            <TextView
                android:id="@+id/lbl_email"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/register_label_email"
                android:textAppearance="@style/TextAppearance.ProvaAndroid.Label"
                android:labelFor="@id/et_email" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="@string/register_hint_email"
                android:inputType="textEmailAddress"
                android:imeOptions="actionNext"
                android:maxLines="1"
                android:autofillHints="emailAddress"
                style="@style/Widget.ProvaAndroid.EditText" />

            <!-- ── Campo Senha ── -->
            <TextView
                android:id="@+id/lbl_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/register_label_password"
                android:textAppearance="@style/TextAppearance.ProvaAndroid.Label"
                android:labelFor="@id/et_password" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/register_hint_password"
                    android:inputType="textPassword"
                    android:imeOptions="actionNext"
                    android:maxLines="1"
                    android:paddingEnd="48dp"
                    android:autofillHints="newPassword"
                    style="@style/Widget.ProvaAndroid.EditText" />

                <ImageButton
                    android:id="@+id/iv_toggle_password"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_eye_toggle"
                    android:contentDescription="Mostrar ou esconder senha"
                    android:padding="12dp" />

            </FrameLayout>

            <!-- ── Campo Confirmar Senha ── -->
            <TextView
                android:id="@+id/lbl_password_confirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/register_label_password_confirm"
                android:textAppearance="@style/TextAppearance.ProvaAndroid.Label"
                android:labelFor="@id/et_password_confirm" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp">

                <EditText
                    android:id="@+id/et_password_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/register_hint_password_confirm"
                    android:inputType="textPassword"
                    android:imeOptions="actionDone"
                    android:maxLines="1"
                    android:paddingEnd="48dp"
                    android:autofillHints="newPassword"
                    style="@style/Widget.ProvaAndroid.EditText" />

                <ImageButton
                    android:id="@+id/iv_toggle_password_confirm"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="end|center_vertical"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_eye_toggle"
                    android:contentDescription="Mostrar ou esconder confirmação de senha"
                    android:padding="12dp" />

            </FrameLayout>

            <!-- Botão Cadastrar (verde) -->
            <Button
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/register_btn_save"
                android:contentDescription="@string/register_btn_save"
                android:drawableStart="@android:drawable/ic_menu_save"
                android:drawablePadding="8dp"
                style="@style/Widget.ProvaAndroid.Button.Secondary" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>