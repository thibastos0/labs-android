<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/weather_primary">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbarHome"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/weather_primary"
        app:title="@string/app_name"
        app:titleTextColor="@color/white"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivLogout"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end"
            android:layout_marginEnd="16dp"
            android:src="@android:drawable/ic_lock_power_off"
            android:contentDescription="@string/menu_logout"
            app:tint="@color/white" />
    </androidx.appcompat.widget.Toolbar>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_left_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.08" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_right_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.92" />

    <ImageView
        android:id="@+id/ivFavorite"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="16dp"
        android:src="@drawable/ic_heart_border"
        android:contentDescription="Favoritar localidade"
        app:layout_constraintTop_toBottomOf="@id/toolbarHome"
        app:layout_constraintRight_toRightOf="@id/gl_right_home"
        app:tint="@color/white" />

    <ImageView
        android:id="@+id/ivWeatherIcon"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="24dp"
        android:src="@android:drawable/ic_menu_report_image"
        app:layout_constraintTop_toBottomOf="@id/ivFavorite"
        app:layout_constraintStart_toStartOf="@id/gl_left_home"
        app:layout_constraintEnd_toEndOf="@id/gl_right_home"/>

    <TextView
        android:id="@+id/tvTemperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25°C"
        android:textSize="72sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/ivWeatherIcon"
        app:layout_constraintStart_toStartOf="@id/gl_left_home"
        app:layout_constraintEnd_toEndOf="@id/gl_right_home"/>

    <EditText
        android:id="@+id/etCurrentCity"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="@string/hint_city"
        android:textColorHint="@color/gray_text"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:textSize="16sp"
        android:background="@color/edit_text_bg"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTemperature"
        app:layout_constraintStart_toStartOf="@id/gl_left_home"
        app:layout_constraintEnd_toEndOf="@id/gl_right_home"/>

    <Button
        android:id="@+id/btnUpdateCity"
        style="@style/WeatherButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="@string/btn_update_city"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/etCurrentCity"
        app:layout_constraintStart_toStartOf="@id/gl_left_home"
        app:layout_constraintEnd_toEndOf="@id/gl_right_home"/>

    <Button
        android:id="@+id/btnGoToFavorites"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="@string/menu_favorites"
        android:textColor="@color/weather_secondary"
        app:strokeColor="@color/weather_secondary"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnUpdateCity"
        app:layout_constraintStart_toStartOf="@id/gl_left_home"
        app:layout_constraintEnd_toEndOf="@id/gl_right_home"/>

    <Button
        android:id="@+id/btnGoToProfile"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:text="@string/menu_profile"
        android:textColor="@color/gray_text"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/btnGoToFavorites"
        app:layout_constraintStart_toStartOf="@id/gl_left_home"
        app:layout_constraintEnd_toEndOf="@id/gl_right_home"/>

</androidx.constraintlayout.widget.ConstraintLayout>